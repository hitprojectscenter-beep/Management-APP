# ============================================
# Work OS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# --- Database (Neon / Vercel Postgres / local) ---
DATABASE_URL="postgresql://user:password@host:5432/work_os"

# --- Auth.js ---
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# --- Google OAuth (for login + Calendar sync) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Anthropic API (Claude AI) ---
ANTHROPIC_API_KEY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DEFAULT_LOCALE="he"

# --- Notifications: Email (real auto-send) ---
# Gmail SMTP (primary). GMAIL_APP_PASSWORD is a 16-char Google App Password.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# Resend (fallback). Optional.
RESEND_API_KEY=""
RESEND_FROM_ADDRESS=""

# --- Notifications: WhatsApp (auto-send) ---
# Pick ONE provider. Real WhatsApp auto-send requires an approved Business
# sender (a WhatsApp platform rule). The first configured provider wins:
#
# 1) Twilio (recommended — free trial + free sandbox for testing).
#    Sandbox: each recipient first sends "join <word>" to the sandbox number.
#    Get these from the Twilio console → Messaging → WhatsApp.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"   # sandbox number, or your approved number
#
# 2) Meta WhatsApp Cloud API (free tier; business-initiated text needs the 24h
#    window or an approved template).
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
#
# 3) Generic webhook — any custom endpoint that accepts { to, message }.
WHATSAPP_WEBHOOK_URL=""
WHATSAPP_API_TOKEN=""

# --- Feature flags ---
ENABLE_AI=true
ENABLE_CALENDAR_SYNC=false
USE_MOCK_DATA=true
